{
    "name": "andryshok/cart",
    "description": "Laravel 5 Shopping cart",
    "keywords": [
        "laravel",
        "shopping cart",
        "cart"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Darryl Fernandez",
            "email": "engrdarrylfernandez@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.3",
        "illuminate/support": "^13.0",
        "illuminate/validation": "^13.0",
        "illuminate/translation": "^13.0"
    },
    "require-dev": {
        "mockery/mockery": "^1.6",
        "phpunit/phpunit": "^12.0",
        "symfony/var-dumper": "5.1.5.*@dev|^7.4"
    },
    "autoload": {
        "psr-4": {
            "Darryldecode\\": "src/Darryldecode"
        }
    },
    "minimum-stability": "dev",
    "extra": {
        "laravel": {
            "providers": [
                "Darryldecode\\Cart\\CartServiceProvider"
            ],
            "aliases": {
                "Cart": "Darryldecode\\Cart\\Facades\\CartFacade"
            }
        }
    }
}
